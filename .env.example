# Ключ API: my.novaposhta.ua → Налаштування → Безпека → API ключі
VITE_NOVA_POSHTA_API_KEY=

# У `npm run dev` запити до НП автоматично йдуть через проксі /np-api/ (без CORS).
# Для production-збірки, якщо браузер блокує прямий api.novaposhta.ua, вкажіть URL свого проксі:
# VITE_NOVA_POSHTA_API_URL=https://ваш-домен.com/api/np/
